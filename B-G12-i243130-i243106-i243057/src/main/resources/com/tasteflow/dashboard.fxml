<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/11"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.tasteflow.controller.DashboardController">

    <!-- ==================== LEFT SIDEBAR NAV ==================== -->
    <left>
        <VBox spacing="6" prefWidth="230" styleClass="sidebar">

            <!-- App Title -->
            <VBox alignment="CENTER" spacing="4" styleClass="app-header">
                <Label text="TasteFlow"
                       style="-fx-font-size: 22; -fx-font-weight: bold;"/>
                <Label text="Restaurant Management"
                       style="-fx-font-size: 11; -fx-text-fill: #666666;"/>
            </VBox>

            <padding><Insets top="0" right="10" bottom="10" left="10"/></padding>

            <Label text="MODULES" styleClass="section-title"/>

            <Button fx:id="btnPOS" text="POS (Dine-In)" onAction="#handlePOSClick"
                    maxWidth="1.7976931348623157E308" contentDisplay="LEFT" graphicTextGap="10"/>

            <Button fx:id="btnKDS" text="Kitchen Display" onAction="#handleKDSClick"
                    maxWidth="1.7976931348623157E308" contentDisplay="LEFT" graphicTextGap="10"/>

            <Button fx:id="btnMenu" text="Menu &amp; Recipes" onAction="#handleMenuClick"
                    maxWidth="1.7976931348623157E308" contentDisplay="LEFT" graphicTextGap="10"/>

            <Button fx:id="btnInventory" text="Inventory &amp; POs" onAction="#handleInventoryClick"
                    maxWidth="1.7976931348623157E308" contentDisplay="LEFT" graphicTextGap="10"/>

            <Button fx:id="btnReservation" text="Reservations" onAction="#handleReservationClick"
                    maxWidth="1.7976931348623157E308" contentDisplay="LEFT" graphicTextGap="10"/>

            <Button fx:id="btnCustomers" text="Customers" onAction="#handleCustomersClick"
                    maxWidth="1.7976931348623157E308" contentDisplay="LEFT" graphicTextGap="10"/>

            <Button fx:id="btnDelivery" text="Deliveries" onAction="#handleDeliveryClick"
                    maxWidth="1.7976931348623157E308" contentDisplay="LEFT" graphicTextGap="10"/>

            <Button fx:id="btnSchedule" text="Staff Schedule" onAction="#handleScheduleClick"
                    maxWidth="1.7976931348623157E308" contentDisplay="LEFT" graphicTextGap="10"/>

            <Button fx:id="btnInvDashboard" text="Inv. Dashboard" onAction="#handleInvDashboardClick"
                    maxWidth="1.7976931348623157E308" contentDisplay="LEFT" graphicTextGap="10"/>

            <Button fx:id="btnDiagnostics" text="Diagnostics" onAction="#handleDiagnosticsClick"
                    maxWidth="1.7976931348623157E308" contentDisplay="LEFT" graphicTextGap="10"/>

            <!-- Spacer -->
            <VBox VBox.vgrow="ALWAYS"/>

            <Separator/>

            <Button fx:id="btnThemeToggle" text="Light Mode" onAction="#handleThemeToggle"
                    maxWidth="1.7976931348623157E308" contentDisplay="LEFT" graphicTextGap="10"
                    style="-fx-font-size: 12;"/>

            <Label fx:id="navStatusLabel" text="Ready" styleClass="status-bar"/>
        </VBox>
    </left>

    <!-- ==================== CENTER: CONTENT AREA ==================== -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area">
            <VBox alignment="CENTER" spacing="12">
                <Label text="Welcome to TasteFlow"
                       style="-fx-font-size: 28; -fx-font-weight: bold;"/>
                <Label text="Select a module from the sidebar to get started."
                       style="-fx-font-size: 14; -fx-text-fill: #666666;"/>
            </VBox>
        </StackPane>
    </center>

</BorderPane>
