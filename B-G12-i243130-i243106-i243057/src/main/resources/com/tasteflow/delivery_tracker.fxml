<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.geometry.Insets?>

<VBox spacing="12"
      xmlns="http://javafx.com/javafx/11"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.tasteflow.controller.DeliveryController">

    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

    <!-- Header -->
    <Label text="🚚 Delivery Tracker"
           style="-fx-font-size: 20; -fx-font-weight: bold;"/>
    <Label text="Dispatch and track delivery orders in real-time"
           style="-fx-font-size: 11; -fx-text-fill: #A0A0A0;"/>

    <Separator/>

    <!-- Top controls -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="+ New Delivery Order" onAction="#handleNewDelivery" styleClass="btn-success"
                style="-fx-font-weight: bold;"/>
        <Button text="⚡ Simulate External Order" onAction="#handleSimulateExternal"
                style="-fx-background-color: #D97706; -fx-text-fill: white; -fx-font-size: 12;
                       -fx-background-radius: 10;"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="Show Active" onAction="#handleShowActive" styleClass="btn-primary"/>
        <Button text="Show All Today" onAction="#handleShowAll"/>
    </HBox>

    <!-- Delivery Table -->
    <TableView fx:id="deliveryTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId"       text="ID"       prefWidth="45"/>
            <TableColumn fx:id="colOrderId"  text="Order #"  prefWidth="60"/>
            <TableColumn fx:id="colPlatform" text="Platform" prefWidth="90"/>
            <TableColumn fx:id="colCustomer" text="Customer" prefWidth="120"/>
            <TableColumn fx:id="colAddress"  text="Address"  prefWidth="160"/>
            <TableColumn fx:id="colPhone"    text="Phone"    prefWidth="100"/>
            <TableColumn fx:id="colRider"    text="Rider"    prefWidth="110"/>
            <TableColumn fx:id="colStatus"   text="Status"   prefWidth="130"/>
            <TableColumn fx:id="colFee"      text="Fee"      prefWidth="60"/>
            <TableColumn fx:id="colTotal"    text="Order $"  prefWidth="70"/>
        </columns>
    </TableView>

    <Separator/>

    <!-- Dispatch Controls -->
    <Label text="Dispatch Controls" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Assign Rider:"/>
        <ComboBox fx:id="riderCombo" prefWidth="180" promptText="Select rider..."/>
        <Button text="Assign" onAction="#handleAssignRider" styleClass="btn-primary"/>

        <Separator orientation="VERTICAL"/>

        <Label text="Update Status:"/>
        <ComboBox fx:id="statusCombo" prefWidth="150" promptText="Select status..."/>
        <Button text="Update" onAction="#handleUpdateStatus" styleClass="btn-primary"/>

        <Separator orientation="VERTICAL"/>

        <Button text="📋 History" onAction="#handleViewHistory"/>
    </HBox>

    <!-- Status -->
    <Label fx:id="statusLabel" text="" wrapText="true"
           style="-fx-font-size: 11; -fx-text-fill: #A0A0A0;"/>

</VBox>
