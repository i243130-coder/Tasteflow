<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.geometry.Insets?>

<VBox spacing="10"
      xmlns="http://javafx.com/javafx/11"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.tasteflow.controller.KDSController">

    <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>

    <!-- Header -->
    <HBox spacing="15" alignment="CENTER_LEFT">
        <Label text="KITCHEN DISPLAY"
               style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #EF4444;"/>
        <Label fx:id="ticketCountLabel" text="0 tickets"
               style="-fx-font-size: 14; -fx-text-fill: #A0A0A0;"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Label fx:id="clockLabel" text="00:00:00"
               style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #EF4444;"/>
        <Label fx:id="pollingLabel" text="LIVE"
               style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #22C55E;
                      -fx-background-color: rgba(34,197,94,0.2); -fx-padding: 3 8;
                      -fx-background-radius: 4;"/>
    </HBox>

    <Separator/>

    <!-- Status bar -->
    <Label fx:id="statusLabel" text=""
           style="-fx-font-size: 11; -fx-text-fill: #A0A0A0;"/>

    <!-- Ticket grid -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <FlowPane fx:id="ticketPane" hgap="12" vgap="12" prefWrapLength="900"/>
    </ScrollPane>

</VBox>
