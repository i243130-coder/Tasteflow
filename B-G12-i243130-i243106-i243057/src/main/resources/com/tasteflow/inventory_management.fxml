<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.Separator?>
<?import javafx.geometry.Insets?>

<TabPane tabClosingPolicy="UNAVAILABLE"
         xmlns="http://javafx.com/javafx/11"
         xmlns:fx="http://javafx.com/fxml/1"
         fx:controller="com.tasteflow.controller.InventoryController">

    <tabs>
        <!-- ====================== TAB 1: STOCK OVERVIEW ====================== -->
        <Tab text="📦 Ingredient Stock">
            <VBox spacing="12">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                <Label text="Current Ingredient Stock" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
                <Separator/>

                <TableView fx:id="stockTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="stkIdCol"      text="ID"           prefWidth="45"/>
                        <TableColumn fx:id="stkNameCol"    text="Ingredient"   prefWidth="160"/>
                        <TableColumn fx:id="stkUnitCol"    text="Unit"         prefWidth="70"/>
                        <TableColumn fx:id="stkQtyCol"     text="Stock"        prefWidth="90"/>
                        <TableColumn fx:id="stkReorderCol" text="Reorder Lvl"  prefWidth="90"/>
                        <TableColumn fx:id="stkCostCol"    text="Cost/Unit ($)" prefWidth="100"/>
                        <TableColumn fx:id="stkStatusCol"  text="Status"       prefWidth="100"/>
                    </columns>
                </TableView>

                <HBox spacing="10">
                    <Button text="↻ Refresh Stock" onAction="#handleRefreshStock"/>
                </HBox>
            </VBox>
        </Tab>

        <!-- ====================== TAB 2: SUPPLIERS ====================== -->
        <Tab text="🏭 Suppliers">
            <VBox spacing="12">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                <Label text="Manage Suppliers" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
                <Separator/>

                <GridPane hgap="10" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints minWidth="120" prefWidth="120"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>

                    <Label text="Name:"    GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="supplierNameField" promptText="Supplier name" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Contact:"  GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="supplierContactField" promptText="Contact person" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Phone:"    GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextField fx:id="supplierPhoneField" promptText="Phone" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <Label text="Email:"    GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <TextField fx:id="supplierEmailField" promptText="Email" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                    <Label text="Address:"  GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <TextField fx:id="supplierAddressField" promptText="Address" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                </GridPane>

                <HBox spacing="10">
                    <Button text="Save Supplier" onAction="#handleSaveSupplier" styleClass="btn-success"
                            style="-fx-font-weight: bold;"/>
                    <Button text="Clear" onAction="#handleClearSupplier"/>
                </HBox>

                <Separator/>

                <TableView fx:id="supplierTable" prefHeight="250" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="supIdCol"      text="ID"      prefWidth="45"/>
                        <TableColumn fx:id="supNameCol"    text="Name"    prefWidth="160"/>
                        <TableColumn fx:id="supContactCol" text="Contact" prefWidth="120"/>
                        <TableColumn fx:id="supPhoneCol"   text="Phone"   prefWidth="120"/>
                        <TableColumn fx:id="supEmailCol"   text="Email"   prefWidth="160"/>
                    </columns>
                </TableView>

                <Label fx:id="supplierStatusLabel" text="" style="-fx-font-size: 12;"/>
            </VBox>
        </Tab>

        <!-- ====================== TAB 3: PURCHASE ORDERS ====================== -->
        <Tab text="📋 Purchase Orders">
            <VBox spacing="12">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                <Label text="Create Purchase Order" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
                <Separator/>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <ComboBox fx:id="poSupplierCombo" promptText="Select Supplier" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                    <Button text="➕ New Supplier" onAction="#handleAddNewSupplierInline" styleClass="btn-primary"
                            style="-fx-font-size: 11;"/>
                    <DatePicker fx:id="poDatePicker" promptText="Expected Delivery"/>
                </HBox>

                <Label text="Line Items" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <ComboBox fx:id="poIngredientCombo" promptText="Ingredient" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
                    <Button text="➕ New Ingredient" onAction="#handleAddNewIngredientInline" styleClass="btn-primary"
                            style="-fx-font-size: 11;"/>
                    <TextField fx:id="poQtyField" promptText="Qty" prefWidth="80"/>
                    <TextField fx:id="poPriceField" promptText="Unit $" prefWidth="80"/>
                    <Button text="Add Line" onAction="#handleAddPOLine"/>
                    <Button text="Remove" onAction="#handleRemovePOLine" styleClass="btn-danger"/>
                </HBox>

                <TableView fx:id="poLineTable" prefHeight="140">
                    <columns>
                        <TableColumn fx:id="poLineIngCol"  text="Ingredient" prefWidth="160"/>
                        <TableColumn fx:id="poLineQtyCol"  text="Qty"        prefWidth="80"/>
                        <TableColumn fx:id="poLineUnitCol" text="Unit"       prefWidth="70"/>
                        <TableColumn fx:id="poLinePrcCol"  text="Unit $"     prefWidth="80"/>
                        <TableColumn fx:id="poLineTotCol"  text="Total $"    prefWidth="90"/>
                    </columns>
                </TableView>

                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Label fx:id="poTotalLabel" text="Total: $0.00" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
                    <Button text="Clear" onAction="#handleClearPO"/>
                    <Button text="Submit PO" onAction="#handleSubmitPO" styleClass="btn-success"
                            style="-fx-font-weight: bold;"/>
                </HBox>

                <Separator/>

                <Label text="All Purchase Orders" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
                <TableView fx:id="poTable" prefHeight="180" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="poIdCol"       text="PO #"       prefWidth="60"/>
                        <TableColumn fx:id="poSupCol"      text="Supplier"   prefWidth="140"/>
                        <TableColumn fx:id="poDateCol"     text="Order Date" prefWidth="120"/>
                        <TableColumn fx:id="poExpCol"      text="Expected"   prefWidth="100"/>
                        <TableColumn fx:id="poAmtCol"      text="Total ($)"  prefWidth="90"/>
                        <TableColumn fx:id="poStatusCol"   text="Status"     prefWidth="110"/>
                    </columns>
                </TableView>

                <HBox spacing="10">
                    <Button text="↻ Refresh" onAction="#handleRefreshPOs"/>
                    <Button text="✅ Mark Received" onAction="#handleReceivePO" styleClass="btn-primary"
                            style="-fx-font-weight: bold;"/>
                    <Button text="❌ Cancel PO" onAction="#handleCancelPO" styleClass="btn-danger"/>
                </HBox>

                <Label fx:id="poStatusLabel" text="" style="-fx-font-size: 12;"/>
            </VBox>
        </Tab>
    </tabs>
</TabPane>
