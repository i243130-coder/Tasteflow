<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.geometry.Insets?>

<!-- ═══════════════════════════════════════════════════════════════
     Inventory Dashboard — Low Stock Alerts + Full Inventory View
     Module: Automated Recipe-Level Inventory Deduction
     For: General Manager
     ═══════════════════════════════════════════════════════════════ -->
<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.tasteflow.controller.InventoryDashboardController">

    <!-- ─────────────── TOP: Header + Stats ─────────────── -->
    <top>
        <VBox spacing="12" styleClass="card">
            <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="16">
                <Label text="📦 Inventory Dashboard" style="-fx-font-size: 22; -fx-font-weight: bold;"/>
                <VBox HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnRefresh" text="⟳  Refresh" onAction="#handleRefresh"/>
            </HBox>

            <!-- Stat Cards Row -->
            <HBox spacing="16" alignment="CENTER_LEFT">
                <!-- Critical Alerts Card -->
                <VBox spacing="4" alignment="CENTER" styleClass="card"
                      style="-fx-min-width: 160; -fx-border-color: #EF4444;">
                    <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                    <Label fx:id="lblCriticalCount" text="0" styleClass="stat-value"
                           style="-fx-text-fill: #EF4444;"/>
                    <Label text="Critical (Out of Stock)" styleClass="stat-label"/>
                </VBox>

                <!-- Warning Alerts Card -->
                <VBox spacing="4" alignment="CENTER" styleClass="card"
                      style="-fx-min-width: 160; -fx-border-color: #F59E0B;">
                    <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                    <Label fx:id="lblWarningCount" text="0" styleClass="stat-value"
                           style="-fx-text-fill: #F59E0B;"/>
                    <Label text="Low Stock Warnings" styleClass="stat-label"/>
                </VBox>

                <!-- Total Ingredients Card -->
                <VBox spacing="4" alignment="CENTER" styleClass="card"
                      style="-fx-min-width: 160;">
                    <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                    <Label fx:id="lblTotalIngredients" text="0" styleClass="stat-value"/>
                    <Label text="Total Ingredients" styleClass="stat-label"/>
                </VBox>

                <VBox HBox.hgrow="ALWAYS"/>

                <Label fx:id="lblLastRefresh" text="" styleClass="muted" style="-fx-font-size: 11;"/>
            </HBox>
        </VBox>
    </top>

    <!-- ─────────────── CENTER: Two-panel layout ─────────────── -->
    <center>
        <HBox spacing="16">
            <padding><Insets top="12" right="0" bottom="0" left="0"/></padding>

            <!-- LEFT: Low Stock Alerts Table -->
            <VBox spacing="8" HBox.hgrow="ALWAYS" styleClass="card">
                <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>

                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="🚨 Low Stock Alerts"
                           style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #EF4444;"/>
                    <VBox HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblAlertCount" text="0 alerts" styleClass="muted"/>
                </HBox>
                <Separator/>

                <TableView fx:id="alertsTable" VBox.vgrow="ALWAYS"
                           style="-fx-min-height: 200;">
                    <columns>
                        <TableColumn fx:id="colAlertSeverity"   text="⚠"            prefWidth="50"/>
                        <TableColumn fx:id="colAlertIngredient" text="Ingredient"    prefWidth="160"/>
                        <TableColumn fx:id="colAlertStock"      text="Current Stock" prefWidth="120"/>
                        <TableColumn fx:id="colAlertReorder"    text="Reorder Level" prefWidth="120"/>
                        <TableColumn fx:id="colAlertDeficit"    text="Deficit"       prefWidth="100"/>
                        <TableColumn fx:id="colAlertUnit"       text="Unit"          prefWidth="80"/>
                    </columns>
                    <placeholder>
                        <Label text="✅ All ingredients are above reorder levels!"
                               style="-fx-text-fill: #22C55E; -fx-font-size: 14;"/>
                    </placeholder>
                </TableView>
            </VBox>

            <!-- RIGHT: Full Inventory Table -->
            <VBox spacing="8" HBox.hgrow="ALWAYS" styleClass="card">
                <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>

                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="📋 All Ingredients"
                           style="-fx-font-size: 16; -fx-font-weight: bold;"/>
                    <VBox HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblInventoryCount" text="0 items" styleClass="muted"/>
                </HBox>
                <Separator/>

                <TableView fx:id="inventoryTable" VBox.vgrow="ALWAYS"
                           style="-fx-min-height: 200;">
                    <columns>
                        <TableColumn fx:id="colInvName"     text="Ingredient"    prefWidth="170"/>
                        <TableColumn fx:id="colInvStock"    text="Current Stock" prefWidth="120"/>
                        <TableColumn fx:id="colInvReorder"  text="Reorder Level" prefWidth="120"/>
                        <TableColumn fx:id="colInvUnit"     text="Unit"          prefWidth="80"/>
                        <TableColumn fx:id="colInvCost"     text="Cost/Unit"     prefWidth="100"/>
                        <TableColumn fx:id="colInvStatus"   text="Status"        prefWidth="100"/>
                    </columns>
                    <placeholder>
                        <Label text="No ingredients found."
                               style="-fx-text-fill: #666666; -fx-font-size: 14;"/>
                    </placeholder>
                </TableView>
            </VBox>
        </HBox>
    </center>

</BorderPane>
