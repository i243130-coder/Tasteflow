<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.geometry.Insets?>

<!-- ═══════════════════════════════════════════════════════════════
     Staff Schedule — Weekly Shift View & Assignment
     Module: Manage Staff Shifts and Scheduling
     ═══════════════════════════════════════════════════════════════ -->
<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.tasteflow.controller.ScheduleController">

    <!-- ─────────────── TOP: Header + Week Nav ─────────────── -->
    <top>
        <VBox spacing="12" styleClass="card">
            <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="16">
                <Label text="📅 Staff Schedule" style="-fx-font-size: 22; -fx-font-weight: bold;"/>
                <VBox HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblStatus" text="" styleClass="muted" style="-fx-font-size: 12;"/>
            </HBox>

            <!-- Week navigation -->
            <HBox alignment="CENTER" spacing="16">
                <Button fx:id="btnPrevWeek" text="◀  Prev Week" onAction="#handlePrevWeek"/>
                <Label fx:id="lblWeekRange" text="Week of ..."
                       style="-fx-font-size: 16; -fx-font-weight: bold;"/>
                <Button fx:id="btnNextWeek" text="Next Week  ▶" onAction="#handleNextWeek"/>
            </HBox>
        </VBox>
    </top>

    <!-- ─────────────── CENTER: Weekly Shift Table ─────────────── -->
    <center>
        <VBox spacing="12">
            <padding><Insets top="12" right="0" bottom="0" left="0"/></padding>

            <TableView fx:id="shiftTable" VBox.vgrow="ALWAYS"
                       style="-fx-min-height: 280;">
                <columns>
                    <TableColumn fx:id="colDay"      text="Day"        prefWidth="100"/>
                    <TableColumn fx:id="colDate"     text="Date"       prefWidth="100"/>
                    <TableColumn fx:id="colStaff"    text="Staff"      prefWidth="150"/>
                    <TableColumn fx:id="colRole"     text="Role"       prefWidth="120"/>
                    <TableColumn fx:id="colTime"     text="Time"       prefWidth="130"/>
                    <TableColumn fx:id="colBranch"   text="Branch"     prefWidth="130"/>
                    <TableColumn fx:id="colStatus"   text="Status"     prefWidth="100"/>
                    <TableColumn fx:id="colActions"  text=""           prefWidth="90"/>
                </columns>
                <placeholder>
                    <Label text="No shifts scheduled for this week."
                           style="-fx-text-fill: #666666; -fx-font-size: 14;"/>
                </placeholder>
            </TableView>
        </VBox>
    </center>

    <!-- ─────────────── BOTTOM: Assign Shift Form ─────────────── -->
    <bottom>
        <VBox spacing="12" styleClass="card">
            <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>

            <Label text="Assign New Shift" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
            <Separator/>

            <HBox spacing="14" alignment="CENTER_LEFT">
                <!-- Staff -->
                <VBox spacing="4">
                    <Label text="Staff Member" styleClass="muted" style="-fx-font-size: 11;"/>
                    <ComboBox fx:id="cmbStaff" promptText="Select staff..."
                              prefWidth="180"/>
                </VBox>

                <!-- Branch -->
                <VBox spacing="4">
                    <Label text="Branch" styleClass="muted" style="-fx-font-size: 11;"/>
                    <ComboBox fx:id="cmbBranch" promptText="Select branch..."
                              prefWidth="160"/>
                </VBox>

                <!-- Date -->
                <VBox spacing="4">
                    <Label text="Date" styleClass="muted" style="-fx-font-size: 11;"/>
                    <DatePicker fx:id="dpShiftDate" prefWidth="140"/>
                </VBox>

                <!-- Start Time -->
                <VBox spacing="4">
                    <Label text="Start" styleClass="muted" style="-fx-font-size: 11;"/>
                    <ComboBox fx:id="cmbStartTime" promptText="Start..."
                              prefWidth="100"/>
                </VBox>

                <!-- End Time -->
                <VBox spacing="4">
                    <Label text="End" styleClass="muted" style="-fx-font-size: 11;"/>
                    <ComboBox fx:id="cmbEndTime" promptText="End..."
                              prefWidth="100"/>
                </VBox>

                <!-- Role -->
                <VBox spacing="4">
                    <Label text="Role" styleClass="muted" style="-fx-font-size: 11;"/>
                    <ComboBox fx:id="cmbRole" promptText="Role..."
                              prefWidth="140"/>
                </VBox>

                <!-- Assign Button -->
                <VBox spacing="4">
                    <Label text=" " style="-fx-font-size: 11;"/>
                    <Button fx:id="btnAssign" text="✚  Assign Shift"
                            onAction="#handleAssignShift" styleClass="btn-primary"/>
                </VBox>
            </HBox>

            <Label fx:id="lblFormStatus" text="" style="-fx-font-size: 12;"/>
        </VBox>
    </bottom>

</BorderPane>
