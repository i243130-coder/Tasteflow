<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.Separator?>
<?import javafx.geometry.Insets?>

<VBox spacing="12"
      xmlns="http://javafx.com/javafx/11"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.tasteflow.controller.CustomerController">

    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

    <!-- Header -->
    <Label text="Customer &amp; Loyalty Management"
           style="-fx-font-size: 20; -fx-font-weight: bold;"/>

    <Separator/>

    <!-- Top bar: search + add -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Search by name or phone..." prefWidth="260"/>
        <Button text="Search" onAction="#handleSearch" styleClass="btn-primary"/>
        <Button text="Show All" onAction="#handleShowAll"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="+ Register Customer" onAction="#handleRegister" styleClass="btn-success"
                style="-fx-font-weight: bold;"/>
    </HBox>

    <!-- Customer Table -->
    <TableView fx:id="customerTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId"     text="ID"        prefWidth="50"/>
            <TableColumn fx:id="colName"   text="Full Name" prefWidth="160"/>
            <TableColumn fx:id="colPhone"  text="Phone"     prefWidth="120"/>
            <TableColumn fx:id="colEmail"  text="Email"     prefWidth="170"/>
            <TableColumn fx:id="colPoints" text="Points"    prefWidth="80"/>
            <TableColumn fx:id="colTier"   text="Tier"      prefWidth="90"/>
            <TableColumn fx:id="colDate"   text="Joined"    prefWidth="130"/>
        </columns>
    </TableView>

    <!-- Summary bar -->
    <HBox spacing="20" alignment="CENTER_LEFT">
        <Label fx:id="summaryLabel" text="0 customers"
               style="-fx-font-size: 12; -fx-text-fill: #A0A0A0;"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="Award Points" onAction="#handleAwardPoints" styleClass="btn-primary"/>
        <Button text="View History" onAction="#handleViewHistory"/>
    </HBox>

    <Label fx:id="statusLabel" text=""
           style="-fx-font-size: 11; -fx-text-fill: #A0A0A0;"/>

</VBox>
