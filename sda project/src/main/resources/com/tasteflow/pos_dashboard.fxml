<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.geometry.Insets?>

<HBox spacing="0"
      xmlns="http://javafx.com/javafx/11"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.tasteflow.controller.POSController">

    <!-- ============== LEFT: TABLE GRID + MENU ITEMS ============== -->
    <VBox spacing="10" HBox.hgrow="ALWAYS">
        <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>

        <!-- Table Selection -->
        <Label text="Select Table" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
        <ScrollPane fitToWidth="true" prefHeight="100">
            <FlowPane fx:id="tableGrid" hgap="8" vgap="8" prefWrapLength="600"/>
        </ScrollPane>

        <Separator/>

        <!-- Menu Items -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Menu Items" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
            <ComboBox fx:id="categoryFilter" promptText="All Categories"
                      onAction="#handleCategoryFilter"/>
        </HBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
            <FlowPane fx:id="menuGrid" hgap="8" vgap="8" prefWrapLength="600"/>
        </ScrollPane>
    </VBox>

    <!-- ============== RIGHT: ORDER CART ============== -->
    <VBox spacing="10" prefWidth="380" styleClass="card"
          style="-fx-border-width: 0 0 0 1;">
        <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>

        <Label fx:id="orderTitleLabel" text="New Order"
               style="-fx-font-size: 18; -fx-font-weight: bold;"/>
        <Label fx:id="tableInfoLabel" text="No table selected"
               style="-fx-font-size: 12; -fx-text-fill: #A0A0A0;"/>

        <Separator/>

        <!-- Cart items -->
        <TableView fx:id="cartTable" VBox.vgrow="ALWAYS" prefHeight="300">
            <columns>
                <TableColumn fx:id="cartItemCol"  text="Item"     prefWidth="140"/>
                <TableColumn fx:id="cartQtyCol"   text="Qty"      prefWidth="45"/>
                <TableColumn fx:id="cartPriceCol" text="Price"    prefWidth="65"/>
                <TableColumn fx:id="cartSubCol"   text="Subtotal" prefWidth="75"/>
            </columns>
        </TableView>

        <HBox spacing="8">
            <Spinner fx:id="qtySpinner" prefWidth="65"/>
            <Button text="+ Qty" onAction="#handleIncQty"/>
            <Button text="- Qty" onAction="#handleDecQty"/>
            <Button text="Remove" onAction="#handleRemoveItem" styleClass="btn-danger"/>
        </HBox>

        <Separator/>

        <!-- Customer Loyalty -->
        <Label text="Customer Loyalty" style="-fx-font-size: 13; -fx-font-weight: bold;"/>
        <HBox spacing="6" alignment="CENTER_LEFT">
            <TextField fx:id="customerPhoneField" promptText="Phone #" prefWidth="140"/>
            <Button text="Lookup" onAction="#handleLookupCustomer" styleClass="btn-primary"/>
            <Button text="Register" onAction="#handleRegisterCustomer"/>
        </HBox>
        <Label fx:id="customerInfoLabel" text="No customer linked" wrapText="true"
               style="-fx-font-size: 11; -fx-text-fill: #A0A0A0;"/>
        <HBox spacing="6" alignment="CENTER_LEFT">
            <Label text="Redeem:" style="-fx-font-size: 11;"/>
            <Spinner fx:id="redeemSpinner" prefWidth="80"/>
            <Label text="pts" style="-fx-font-size: 11;"/>
            <Button text="Apply Points" onAction="#handleApplyPoints" styleClass="btn-primary"/>
        </HBox>
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Label text="Discount:" style="-fx-font-weight: bold;"/>
            <Label fx:id="discountLabel" text="0.00" style="-fx-text-fill: #A855F7;"/>
        </HBox>

        <Separator/>
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Label text="Subtotal:" style="-fx-font-weight: bold;"/>
            <Label fx:id="subtotalLabel" text="0.00"/>
        </HBox>
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Label text="Tax (10%):" style="-fx-font-weight: bold;"/>
            <Label fx:id="taxLabel" text="0.00"/>
        </HBox>
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Label text="TOTAL:" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
            <Label fx:id="totalLabel" text="0.00"
                   style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #22C55E;"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Clear Cart" onAction="#handleClearCart"/>
            <Button text="Pre-Order" onAction="#handlePreOrder"
                    style="-fx-background-color: #D97706; -fx-text-fill: white;
                           -fx-font-size: 13; -fx-font-weight: bold; -fx-padding: 10 16;
                           -fx-background-radius: 10;"/>
            <Button text="Place Order" onAction="#handlePlaceOrder" styleClass="btn-success"
                    style="-fx-font-size: 14; -fx-font-weight: bold; -fx-padding: 10 20;"/>
        </HBox>

        <Separator/>

        <!-- Recent orders -->
        <Label text="Today's Orders" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
        <TableView fx:id="ordersTable" prefHeight="150">
            <columns>
                <TableColumn fx:id="ordIdCol"     text="#"       prefWidth="40"/>
                <TableColumn fx:id="ordTableCol"  text="Table"  prefWidth="50"/>
                <TableColumn fx:id="ordTotalCol"  text="Total"  prefWidth="70"/>
                <TableColumn fx:id="ordStatusCol" text="Status" prefWidth="85"/>
                <TableColumn fx:id="ordTimeCol"   text="Time"   prefWidth="80"/>
            </columns>
        </TableView>

        <Label fx:id="statusLabel" text="" wrapText="true" style="-fx-font-size: 11;"/>
    </VBox>

</HBox>
